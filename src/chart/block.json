{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "simple-graphs/chart",
  "title": "Simple Graphs",
  "category": "widgets",
  "description": "Create simple, visually-striking charts.",
  "textdomain": "simple-graphs",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": { "margin": true, "padding": true, "blockGap": true },
    "dimensions": { "minHeight": true },
    "color": { "background": true, "text": false, "link": false }
  },
  "attributes": {
    "style": {
      "type": "object",
      "default": {
        "spacing": { "blockGap": "var:preset|spacing|30" },
        "dimensions": { "minHeight": "480px" }
      }
    }
  }
}
